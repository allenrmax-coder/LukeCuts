# ============================================================
# Luke Cuts PSU — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# Google Calendar Integration
# ------------------------------------------------------------
# 1. Go to https://console.cloud.google.com
# 2. Create a new project (e.g. "LukeCuts")
# 3. Enable "Google Calendar API"
# 4. Go to IAM & Admin > Service Accounts > Create Service Account
# 5. Download the JSON key file
# 6. Paste the entire JSON content here (as a single line, or multiline in quotes)
# 7. In Google Calendar, share your calendar with the service account email
#    (the "client_email" field in the JSON) and give it "Make changes to events" permission

GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"lukecutspsu@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# The Calendar ID to book events into.
# Use "primary" for Luke's main Google Calendar,
# or paste a specific calendar ID from Google Calendar settings.
GOOGLE_CALENDAR_ID=primary

# ------------------------------------------------------------
# Email (SMTP) — for confirmation + reminder emails
# ------------------------------------------------------------
# Using Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
# Use that 16-character app password as SMTP_PASS (not your regular password)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=luke@lukecutspsu.com
SMTP_PASS=your-gmail-app-password-here

# Luke's notification email (where new booking alerts go)
LUKE_EMAIL=luke@lukecutspsu.com

# ------------------------------------------------------------
# Instagram Live Feed
# ------------------------------------------------------------
# 1. Go to https://developers.facebook.com
# 2. Create an App > "Consumer" type
# 3. Add "Instagram Basic Display" product
# 4. Generate a long-lived access token for @lukecutspsu
#    (valid 60 days; refresh before expiry)
# Docs: https://developers.facebook.com/docs/instagram-basic-display-api

INSTAGRAM_ACCESS_TOKEN=IGQVJWb...your_long_lived_token_here

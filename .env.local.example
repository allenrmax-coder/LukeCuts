# ============================================================
# Luke Cuts PSU — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# Admin Authentication
# ------------------------------------------------------------
# ADMIN_SECRET — used to sign the daily session token (HMAC-SHA256).
# Set this to a long random string (32+ chars). Keep it secret.
# Example: openssl rand -hex 32
ADMIN_SECRET=replace-with-a-long-random-secret-string

# ADMIN_PASSWORD — the password Luke types on /admin/login.
# Option A (recommended): use a bcrypt hash so the plaintext never lives in env.
#   Generate with: node -e "require('bcryptjs').hash('YourPassword',12).then(console.log)"
#   Then set ADMIN_PASSWORD_HASH below and leave ADMIN_PASSWORD unset.
#
# Option B (simpler, less secure): store the plaintext password directly.
#   The auth route compares it with timingSafeEqual so it is not trivially brute-forceable,
#   but the plaintext is visible in your Vercel dashboard.
#
# Use ONE of the two options — not both.
ADMIN_PASSWORD=your-strong-password-here
# ADMIN_PASSWORD_HASH=$2b$12$...bcrypt-hash-here...

# ------------------------------------------------------------
# Google Calendar Integration
# ------------------------------------------------------------
# 1. Go to https://console.cloud.google.com
# 2. Create a new project (e.g. "LukeCuts")
# 3. Enable "Google Calendar API"
# 4. Go to IAM & Admin > Service Accounts > Create Service Account
# 5. Download the JSON key file
# 6. Paste the entire JSON content on one line as the value below
# 7. In Google Calendar, share Luke's calendar with the service account's
#    client_email and grant "Make changes to events" permission

GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"lukecutspsu@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# The Google Calendar ID to create bookings on.
# Set to Luke's Gmail so events appear directly on his personal calendar.
GOOGLE_CALENDAR_ID=lukephilipsanderson2007@gmail.com

# Luke's email — also added as an attendee on every booking event.
OWNER_EMAIL=lukephilipsanderson2007@gmail.com

# ------------------------------------------------------------
# Email (SMTP) — for confirmation + reminder emails
# ------------------------------------------------------------
# Using Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
# Use that 16-character app password as SMTP_PASS (not your regular password)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=luke@lukecutspsu.com
SMTP_PASS=your-gmail-app-password-here

# Luke's notification email (where new booking alerts go)
LUKE_EMAIL=lukephilipsanderson2007@gmail.com

# ------------------------------------------------------------
# Instagram Live Feed
# ------------------------------------------------------------
# 1. Go to https://developers.facebook.com
# 2. Create an App > "Consumer" type
# 3. Add "Instagram Basic Display" product
# 4. Generate a long-lived access token for @lukecutspsu
#    (valid 60 days; refresh before expiry)
# Docs: https://developers.facebook.com/docs/instagram-basic-display-api

INSTAGRAM_ACCESS_TOKEN=IGQVJWb...your_long_lived_token_here
